generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CrawlTask {
  id                String   @id @default(cuid())
  url               String
  status            Status   @default(PENDING)
  title             String?
  content           String?
  html              String?
  author            String?
  column            String?
  error             String?
  fontDecodeSuccess Boolean  @default(true) // 字体解码是否成功
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  content_preview   String?  @default(dbgenerated("\"left\"(content, 600)"))

  @@index([status, createdAt])
  @@index([status])
  @@index([url])
}

enum Status {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// 系统配置表（存储 Cookie 等配置）
model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// Cookie 可用性检查日志
model CookieCheckLog {
  id        String   @id @default(cuid())
  success   Boolean
  message   String?
  checkedAt DateTime @default(now())

  @@index([checkedAt])
}

// IP 限流记录
model RateLimitLog {
  id        String   @id @default(cuid())
  ip        String
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}
