generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CrawlTask {
  id              String   @id @default(cuid())
  url             String
  status          Status   @default(PENDING)
  title           String?
  content         String?
  html            String?
  author          String?
  column          String?
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  content_preview String?  @default(dbgenerated("\"left\"(content, 600)"))

@@index([status, createdAt])
@@index([status])
@@index([url])
}

enum Status {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
