generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CrawlTask {
  id        String   @id @default(cuid())
  url       String
  status    Status   @default(PENDING)
  title     String?
  content   String?  @db.Text
  html      String?  @db.Text
  author    String?
  column    String?  // 专栏名称，导入时从父文件夹名获取
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
