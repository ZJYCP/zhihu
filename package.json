{
  "name": "zhihu-crawler",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remix vite:dev",
    "build": "remix vite:build",
    "start": "wrangler pages dev ./build/client",
    "deploy": "wrangler pages deploy ./build/client",
    "lint": "eslint .",
    "typecheck": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply zhihu-crawler --local",
    "db:migrate:prod": "wrangler d1 migrations apply zhihu-crawler --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@cf-wasm/png": "^0.3.2",
    "@cf-wasm/resvg": "^0.3.3",
    "@remix-run/cloudflare": "^2.15.0",
    "@remix-run/cloudflare-pages": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.0",
    "isbot": "^5.1.0",
    "lucide-react": "^0.468.0",
    "opentype.js": "^1.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@remix-run/dev": "^2.15.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/opentype.js": "^1.3.8",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.17.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.0",
    "wrangler": "^3.99.0"
  }
}
