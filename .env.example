# 知乎Cookie配置
ZHIHU_COOKIE=your_cookie_here

# 请求间隔(毫秒)
REQUEST_DELAY=3000

# 输出目录
OUTPUT_DIR=./output

# SiliconFlow OCR API
SILICONFLOW_API_KEY=your_api_key_here

# PostgreSQL 数据库连接
DATABASE_URL="postgresql://postgres:password@localhost:5432/zhihu_crawler?schema=public"

# Browserless.io (Vercel 部署需要)
# BROWSERLESS_TOKEN=your_token_here
