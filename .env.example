# PostgreSQL 数据库连接
DATABASE_URL="postgresql://postgres:password@localhost:5432/zhihu_crawler?schema=public"

# 管理后台密码
ADMIN_PASSWORD=your_admin_password_here

# Token 签名密钥
APP_SECRET=replace_with_a_long_random_secret

# 服务端口
PORT=3000

# 外部系统直接更新 Cookie 的鉴权密钥（可选，不配置则该通道关闭）
EXTERNAL_API_SECRET=your_external_secret_here
